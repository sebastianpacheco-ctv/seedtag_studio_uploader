# Copiá este archivo a .env y completá. NUNCA subas .env al git.

# --- Flask ---
# OBLIGATORIO en producción (la app no arranca sin esto si FLASK_DEBUG!=True).
# Generá una con: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=cambiame-por-algo-random
APP_PORT=8088
# Cookie de sesión Secure (solo viaja por HTTPS). En dev local sobre http, poné False.
SESSION_COOKIE_SECURE=False

# --- Studio ---
# JWT por defecto SOLO para desarrollo. En producción el JWT es POR USUARIO
# (lo pega cada persona / sale del SSO) y vive en su sesión, no acá.
STUDIO_JWT_COOKIE=
# Permitir el fallback al STUDIO_JWT_COOKIE de arriba. SOLO dev; en prod dejá False (A8).
ALLOW_ENV_STUDIO_JWT=False

# --- Jira (para adjuntar/comentar el link en el ticket) ---
JIRA_BASE_URL=https://seedtag.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
# Solo se permite operar sobre tickets de este proyecto:
JIRA_PROJECT_KEY=SDS

# --- Auth de la app: Google OIDC (SSO real) ---
# Si GOOGLE_CLIENT_ID y GOOGLE_CLIENT_SECRET están seteados, se activa el SSO real de
# Google y el login simulado se deshabilita. Si no, en dev (FLASK_DEBUG=True) se usa el
# login simulado. Crear las credenciales en Google Cloud Console → APIs & Services →
# Credentials → OAuth client ID (Web application).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Solo se permite ingresar con correos de este dominio:
ALLOWED_EMAIL_DOMAIN=seedtag.com
# Redirect URI autorizada en la consola de Google. Debe coincidir EXACTO con la URL
# pública + /auth/callback (ej. https://TU-APP.run.app/auth/callback). En local:
# http://127.0.0.1:8088/auth/callback . Si se deja vacío se infiere del request.
OAUTH_REDIRECT_URI=

# --- Local ---
TMP_DIR=./tmp
